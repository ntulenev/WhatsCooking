<Window x:Class="WhatsCooking.MainWindow" x:ClassModifier="internal" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:WhatsCooking" xmlns:views="clr-namespace:WhatsCooking.Views" mc:Ignorable="d" Title="What's Cooking" Height="820" Width="1480" MinHeight="680" MinWidth="1100" AutomationProperties.Name="What's Cooking pull request dashboard" Background="#1E1E1E" FontFamily="Segoe UI" FontSize="13" PreviewKeyDown="OnPreviewKeyDown">
    <Window.InputBindings>
        <KeyBinding Key="OemPlus" Modifiers="Control" Command="{Binding IncreaseUiScaleCommand}" />
        <KeyBinding Key="Add" Modifiers="Control" Command="{Binding IncreaseUiScaleCommand}" />
        <KeyBinding Key="OemMinus" Modifiers="Control" Command="{Binding DecreaseUiScaleCommand}" />
        <KeyBinding Key="Subtract" Modifiers="Control" Command="{Binding DecreaseUiScaleCommand}" />
    </Window.InputBindings>

    <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="Resources/MainWindowResources.xaml" /></ResourceDictionary.MergedDictionaries><local:BindingProxy x:Key="ViewModelProxy" Data="{Binding}" /></ResourceDictionary></Window.Resources>

    <Grid Background="{DynamicResource BgBrush}">
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
        </Grid.LayoutTransform>

    <Grid Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <views:DashboardToolbar Grid.Row="0" />

        <TabControl x:Name="DashboardTabs" Grid.Row="1" Margin="10,8,10,10">
            <TabItem Header="Open PR details">
                <Border Background="{DynamicResource PanelBrush}" BorderBrush="#12FFFFFF" BorderThickness="1" Padding="0">
                    <DataGrid AutomationProperties.Name="Open pull requests" ItemsSource="{Binding OpenPullRequestsView}" PreviewMouseWheel="OnDataGridPreviewMouseWheel">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Number}" SortMemberPath="Number" Width="64">
                                <DataGridTextColumn.Header>
                                    <StackPanel>
                                        <TextBlock Text="#" />
                                        <TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenPullRequestFilters.Number, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged, Delay=250}" />
                                    </StackPanel>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn SortMemberPath="RepositoryName" Width="220">
                                <DataGridTemplateColumn.Header>
                                    <StackPanel>
                                        <TextBlock Text="Repository" />
                                        <TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenPullRequestFilters.Repository, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged, Delay=250}" />
                                    </StackPanel>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource LinkButtonStyle}" Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding RepositoryUrl}">
                                            <TextBlock Text="{Binding RepositoryName}" TextWrapping="Wrap" Foreground="{DynamicResource LinkBrush}" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn SortMemberPath="PullRequestId" Width="380">
                                <DataGridTemplateColumn.Header>
                                    <StackPanel>
                                        <TextBlock Text="PR" />
                                        <TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenPullRequestFilters.PullRequest, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged, Delay=250}" />
                                    </StackPanel>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource LinkButtonStyle}" Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding PullRequestUrl}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding PullRequestId, StringFormat=#\{0\}}" FontWeight="SemiBold" Foreground="{DynamicResource LinkBrush}" />
                                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" Foreground="{DynamicResource LinkBrush}" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding Author}" SortMemberPath="Author" Width="170">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Author" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenPullRequestFilters.Author, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource DescriptionLengthCellTemplate}" SortMemberPath="DescriptionLength" Width="96">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="Desc. len" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenPullRequestFilters.DescriptionLength, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding OpenFor}" SortMemberPath="OpenForMinutes" Width="110">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Open for" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenPullRequestFilters.OpenFor, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource TimeToFirstResponseCellTemplate}" SortMemberPath="TimeToFirstResponseMinutes" Width="110">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="TTFR" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenPullRequestFilters.TimeToFirstResponse, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding ActivityAgeOrMerged}" SortMemberPath="ActivityAgeOrMergedMinutes" Width="110">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Updated" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenPullRequestFilters.Activity, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding CommentsCount}" SortMemberPath="CommentsCount" Width="96">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Comments" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenPullRequestFilters.Comments, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource RequestChangesCellTemplate}" SortMemberPath="RequestChanges" Width="100">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="RC" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenPullRequestFilters.RequestChanges, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource ApprovalsCellTemplate}" SortMemberPath="Approvals" Width="100">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="AP" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenPullRequestFilters.Approvals, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource CurrentUserActivityCellTemplate}" SortMemberPath="CurrentUserActivity" Width="140">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="Me" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenPullRequestFilters.CurrentUserActivity, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="122" CanUserSort="False">
                                <DataGridTemplateColumn.Header>
                                    <StackPanel>
                                        <TextBlock Text="Reviewed" />
                                        <Button Style="{StaticResource ReviewedFilterButtonStyle}"
                                                Content="{Binding Data.OpenReviewedFilterButtonText, Source={StaticResource ViewModelProxy}}"
                                                Command="{Binding Data.ToggleOpenReviewedFilterCommand, Source={StaticResource ViewModelProxy}}"
                                                Tag="{Binding Data.IsOpenReviewedFilterActive, Source={StaticResource ViewModelProxy}}" />
                                    </StackPanel>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsReviewed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="AI review" Width="112" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Copy"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Padding="8,3"
                                                Margin="4"
                                                ToolTip="Copy a PR review prompt with Bitbucket access credentials to the clipboard"
                                                AutomationProperties.Name="Copy pull request review prompt for AI"
                                                Command="{Binding DataContext.CopyForAiCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="Recently merged pull requests">
                <Border Background="{DynamicResource PanelBrush}" BorderBrush="#12FFFFFF" BorderThickness="1" Padding="0">
                    <DataGrid AutomationProperties.Name="Recently merged pull requests" ItemsSource="{Binding MergedPullRequestsView}" PreviewMouseWheel="OnDataGridPreviewMouseWheel">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Number}" SortMemberPath="Number" Width="64">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="#" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding Data.MergedPullRequestFilters.Number, Source={StaticResource ViewModelProxy}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn SortMemberPath="RepositoryName" Width="220">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="Repository" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding Data.MergedPullRequestFilters.Repository, Source={StaticResource ViewModelProxy}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource LinkButtonStyle}" Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding RepositoryUrl}">
                                            <TextBlock Text="{Binding RepositoryName}" TextWrapping="Wrap" Foreground="{DynamicResource LinkBrush}" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn SortMemberPath="PullRequestId" Width="380">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="PR" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding Data.MergedPullRequestFilters.PullRequest, Source={StaticResource ViewModelProxy}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource LinkButtonStyle}" Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding PullRequestUrl}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding PullRequestId, StringFormat=#\{0\}}" FontWeight="SemiBold" Foreground="{DynamicResource LinkBrush}" />
                                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" Foreground="{DynamicResource LinkBrush}" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding Author}" SortMemberPath="Author" Width="170">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Author" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding Data.MergedPullRequestFilters.Author, Source={StaticResource ViewModelProxy}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource DescriptionLengthCellTemplate}" SortMemberPath="DescriptionLength" Width="96">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="Desc. len" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding Data.MergedPullRequestFilters.DescriptionLength, Source={StaticResource ViewModelProxy}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource TimeToFirstResponseCellTemplate}" SortMemberPath="TimeToFirstResponseMinutes" Width="110">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="TTFR" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding Data.MergedPullRequestFilters.TimeToFirstResponse, Source={StaticResource ViewModelProxy}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding ActivityAgeOrMerged}" SortMemberPath="ActivityAgeOrMergedMinutes" Width="110">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Merged" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding Data.MergedPullRequestFilters.Activity, Source={StaticResource ViewModelProxy}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding CommentsCount}" SortMemberPath="CommentsCount" Width="96">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Comments" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding Data.MergedPullRequestFilters.Comments, Source={StaticResource ViewModelProxy}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource RequestChangesCellTemplate}" SortMemberPath="RequestChanges" Width="100">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="RC" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding Data.MergedPullRequestFilters.RequestChanges, Source={StaticResource ViewModelProxy}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource ApprovalsCellTemplate}" SortMemberPath="Approvals" Width="100">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="AP" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding Data.MergedPullRequestFilters.Approvals, Source={StaticResource ViewModelProxy}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource CurrentUserActivityCellTemplate}" SortMemberPath="CurrentUserActivity" Width="140">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="Me" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding Data.MergedPullRequestFilters.CurrentUserActivity, Source={StaticResource ViewModelProxy}, UpdateSourceTrigger=PropertyChanged, Delay=250}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="122" CanUserSort="False">
                                <DataGridTemplateColumn.Header>
                                    <StackPanel>
                                        <TextBlock Text="Reviewed" />
                                        <Button Style="{StaticResource ReviewedFilterButtonStyle}"
                                                Content="{Binding Data.MergedReviewedFilterButtonText, Source={StaticResource ViewModelProxy}}"
                                                Command="{Binding Data.ToggleMergedReviewedFilterCommand, Source={StaticResource ViewModelProxy}}"
                                                Tag="{Binding Data.IsMergedReviewedFilterActive, Source={StaticResource ViewModelProxy}}" />
                                    </StackPanel>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsReviewed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="Telemetry">
                <views:TelemetryView />
            </TabItem>
        </TabControl>
    </Grid>

        <Border x:Name="DialogOverlay"
                Background="#99000000"
                Visibility="Collapsed" />
        <views:LoadingOverlay Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
    </Grid>
</Window>
