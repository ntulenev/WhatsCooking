<Window x:Class="WhatsCooking.MainWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:WhatsCooking.Views"
        mc:Ignorable="d"
        Title="What's Cooking" Height="820" Width="1480" MinHeight="680" MinWidth="1100"
        AutomationProperties.Name="What's Cooking pull request dashboard"
        Background="#1E1E1E"
        FontFamily="Segoe UI"
        FontSize="13"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.InputBindings>
        <KeyBinding Key="OemPlus" Modifiers="Control" Command="{Binding IncreaseUiScaleCommand}" />
        <KeyBinding Key="Add" Modifiers="Control" Command="{Binding IncreaseUiScaleCommand}" />
        <KeyBinding Key="OemMinus" Modifiers="Control" Command="{Binding DecreaseUiScaleCommand}" />
        <KeyBinding Key="Subtract" Modifiers="Control" Command="{Binding DecreaseUiScaleCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="BgBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="PanelBrush" Color="#252526" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#2D2D30" />
        <SolidColorBrush x:Key="BorderBrushDark" Color="#3C3C3C" />
        <SolidColorBrush x:Key="TextBrush" Color="#CCCCCC" />
        <SolidColorBrush x:Key="MutedBrush" Color="#8B8B8B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3794FF" />
        <SolidColorBrush x:Key="LinkBrush" Color="#4FC1FF" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F48771" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#89D185" />
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#343438" />
        <SolidColorBrush x:Key="ControlPressedBrush" Color="#3F3F46" />
        <SolidColorBrush x:Key="InputBrush" Color="#1F1F1F" />
        <SolidColorBrush x:Key="HeaderPanelBrush" Color="#DD252526" />
        <SolidColorBrush x:Key="SubtleBorderBrush" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="DataGridAltRowBrush" Color="#28282B" />
        <SolidColorBrush x:Key="DataGridHorizontalLineBrush" Color="#2D2D30" />
        <SolidColorBrush x:Key="DataGridVerticalLineBrush" Color="#252526" />
        <SolidColorBrush x:Key="DataGridHeaderSelectedBrush" Color="#173B57" />
        <SolidColorBrush x:Key="DisabledButtonBrush" Color="#202024" />
        <SolidColorBrush x:Key="DisabledTextBrush" Color="#777777" />
        <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#0E639C" />
        <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="#1177BB" />
        <SolidColorBrush x:Key="ToggleTrackBrush" Color="#3C3C3C" />
        <SolidColorBrush x:Key="ToggleThumbBrush" Color="#CCCCCC" />
        <SolidColorBrush x:Key="ToggleCheckedTrackBrush" Color="#3794FF" />

        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
            <Setter Property="SelectionBrush" Value="#664FC1FF" />
            <Setter Property="Validation.ErrorTemplate">
                <Setter.Value>
                    <ControlTemplate>
                        <Border BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1">
                            <AdornedElementPlaceholder />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={RelativeSource Self},
                                            Path=(Validation.Errors)[0].ErrorContent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          Foreground="{TemplateBinding Foreground}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                TextElement.Foreground="{TemplateBinding Foreground}">
                                            <Grid>
                                                <ContentPresenter Margin="8,0,28,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Path Width="8"
                                                      Height="5"
                                                      Margin="0,0,9,0"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Fill="{DynamicResource MutedBrush}"
                                                      Data="M 0 0 L 4 5 L 8 0 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ControlPressedBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsKeyboardFocused" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                <Setter TargetName="Border" Property="BorderThickness" Value="2" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource PanelAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ControlPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Border" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource DisabledButtonBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBorderBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ThemeToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <Border x:Name="Track"
                                    CornerRadius="12"
                                    Background="{DynamicResource ToggleTrackBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1" />
                            <Ellipse x:Name="Thumb"
                                     Width="18"
                                     Height="18"
                                     Margin="3"
                                     HorizontalAlignment="Left"
                                     Fill="{DynamicResource ToggleThumbBrush}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource ToggleCheckedTrackBrush}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Fill" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Track" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource LinkBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="LinkFocusBorder"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="LinkFocusBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderFilterTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="AutomationProperties.HelpText" Value="Filter this column" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <DataTemplate x:Key="DescriptionLengthCellTemplate">
            <TextBlock Text="{Binding DescriptionLength}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDescriptionShort}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DataTemplate>

        <DataTemplate x:Key="TimeToFirstResponseCellTemplate">
            <Border x:Name="Badge"
                    Padding="8,2"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="1">
                <TextBlock x:Name="BadgeText" Text="{Binding TimeToFirstResponse}" />
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsTtfrAlert}" Value="True">
                    <Setter TargetName="Badge" Property="BorderBrush" Value="#FF2D20" />
                    <Setter TargetName="Badge" Property="Background" Value="#2AFF2D20" />
                    <Setter TargetName="BadgeText" Property="Foreground" Value="{DynamicResource DangerBrush}" />
                    <Setter TargetName="BadgeText" Property="FontWeight" Value="Bold" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="RequestChangesCellTemplate">
            <Grid>
                <TextBlock x:Name="EmptyText" Text="-" />
                <Border x:Name="Badge"
                        Visibility="Collapsed"
                        Padding="7,2"
                        HorizontalAlignment="Left"
                        Background="#32221F"
                        BorderBrush="#5A2D26"
                        BorderThickness="1"
                        CornerRadius="10">
                    <TextBlock Text="{Binding RequestChanges}" Foreground="#FF8A65" />
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding HasRequestChanges}" Value="True">
                    <Setter TargetName="EmptyText" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="Badge" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="ApprovalsCellTemplate">
            <Grid>
                <TextBlock x:Name="EmptyText" Text="-" />
                <Border x:Name="Badge"
                        Visibility="Collapsed"
                        Padding="7,2"
                        HorizontalAlignment="Left"
                        Background="#1D3324"
                        BorderBrush="#2F5F3B"
                        BorderThickness="1"
                        CornerRadius="10">
                    <TextBlock Text="{Binding Approvals}" Foreground="{DynamicResource SuccessBrush}" />
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding HasApprovals}" Value="True">
                    <Setter TargetName="EmptyText" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="Badge" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="CurrentUserActivityCellTemplate">
            <Grid>
                <TextBlock x:Name="EmptyText" Text="-" />
                <Border x:Name="Badge"
                        Visibility="Collapsed"
                        Padding="7,2"
                        HorizontalAlignment="Left"
                        Background="#2A2636"
                        BorderBrush="#4F4568"
                        BorderThickness="1"
                        CornerRadius="10"
                        ToolTip="{Binding CurrentUserActivity}">
                    <TextBlock Text="{Binding CurrentUserActivity}" Foreground="#D7BAFF" />
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding HasCurrentUserActivity}" Value="True">
                    <Setter TargetName="EmptyText" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="Badge" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasCurrentUserRequestChanges}" Value="True">
                    <Setter TargetName="Badge" Property="Background" Value="#32221F" />
                    <Setter TargetName="Badge" Property="BorderBrush" Value="#5A2D26" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasCurrentUserApproval}" Value="True">
                    <Setter TargetName="Badge" Property="Background" Value="#1D3324" />
                    <Setter TargetName="Badge" Property="BorderBrush" Value="#2F5F3B" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                Padding="{TemplateBinding Padding}"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PanelAltBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#173B57" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0E639C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Background" Value="#565656" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarLineButtonStyle" TargetType="RepeatButton">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}">
                            <Path Width="8"
                                  Height="5"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Fill="{TemplateBinding Foreground}"
                                  Data="M 0 5 L 4 0 L 8 5 Z"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="14" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="14" />
                            </Grid.RowDefinitions>
                            <RepeatButton Grid.Row="0"
                                          Command="ScrollBar.LineUpCommand"
                                          Style="{StaticResource ScrollBarLineButtonStyle}"
                                          Tag="0" />
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="#6A6A6A" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                            <RepeatButton Grid.Row="2"
                                          Command="ScrollBar.LineDownCommand"
                                          Style="{StaticResource ScrollBarLineButtonStyle}"
                                          Tag="180" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="14" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="{TemplateBinding Background}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="14" />
                                    </Grid.ColumnDefinitions>
                                    <RepeatButton Grid.Column="0"
                                                  Command="ScrollBar.LineLeftCommand"
                                                  Style="{StaticResource ScrollBarLineButtonStyle}"
                                                  Tag="270" />
                                    <Track x:Name="PART_Track" Grid.Column="1">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Background="#6A6A6A" />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                    <RepeatButton Grid.Column="2"
                                                  Command="ScrollBar.LineRightCommand"
                                                  Style="{StaticResource ScrollBarLineButtonStyle}"
                                                  Tag="90" />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="MaxWidth" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}" />
            <Setter Property="MaxHeight" Value="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource DataGridHorizontalLineBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource DataGridVerticalLineBrush}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="36" />
            <Setter Property="ColumnHeaderHeight" Value="58" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="{DynamicResource PanelBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource DataGridAltRowBrush}" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Visible" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
            <Setter Property="ScrollViewer.PanningMode" Value="Both" />
            <Setter Property="ScrollViewer.PanningDeceleration" Value="0.001" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="Click to sort" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  RecognizesAccessKey="True" />
                                <TextBlock x:Name="SortGlyph"
                                           Margin="0,4,6,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Top"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBrush}" />
                                <Thumb x:Name="PART_LeftHeaderGripper"
                                       Width="8"
                                       HorizontalAlignment="Left"
                                       Cursor="SizeWE"
                                       Background="Transparent" />
                                <Thumb x:Name="PART_RightHeaderGripper"
                                       Width="8"
                                       HorizontalAlignment="Right"
                                       Cursor="SizeWE"
                                       Background="Transparent" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource LinkBrush}" />
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource DataGridHeaderSelectedBrush}" />
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="SortGlyph" Property="Text" Value="&#x25B2;" />
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource DataGridHeaderSelectedBrush}" />
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="SortGlyph" Property="Text" Value="&#x25BC;" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DataGridHeaderSelectedBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource DataGridAltRowBrush}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsReviewed}" Value="True">
                    <Setter Property="Background" Value="#665E5E5E" />
                    <Setter Property="Opacity" Value="0.58" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DataGridHeaderSelectedBrush}" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource BgBrush}">
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
        </Grid.LayoutTransform>

    <Grid Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <views:DashboardToolbar Grid.Row="0" />

        <TabControl Grid.Row="1" Margin="10,8,10,10">
            <TabItem Header="Open PR details">
                <Border Background="{DynamicResource PanelBrush}" BorderBrush="#12FFFFFF" BorderThickness="1" CornerRadius="12" Padding="0">
                    <DataGrid AutomationProperties.Name="Open pull requests"
                              ItemsSource="{Binding OpenPullRequestsView}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Number}" SortMemberPath="Number" Width="64">
                                <DataGridTextColumn.Header>
                                    <StackPanel>
                                        <TextBlock Text="#" />
                                        <TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenNumberFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn SortMemberPath="RepositoryName" Width="220">
                                <DataGridTemplateColumn.Header>
                                    <StackPanel>
                                        <TextBlock Text="Repository" />
                                        <TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenRepositoryFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding RepositoryUrl}">
                                            <TextBlock Text="{Binding RepositoryName}" TextWrapping="Wrap" Foreground="{DynamicResource LinkBrush}" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn SortMemberPath="PullRequestId" Width="380">
                                <DataGridTemplateColumn.Header>
                                    <StackPanel>
                                        <TextBlock Text="PR" />
                                        <TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenPullRequestFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource LinkButtonStyle}"
                                                Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding PullRequestUrl}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding PullRequestId, StringFormat=#\{0\}}" FontWeight="SemiBold" Foreground="{DynamicResource LinkBrush}" />
                                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" Foreground="{DynamicResource LinkBrush}" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding Author}" SortMemberPath="Author" Width="170">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Author" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenAuthorFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource DescriptionLengthCellTemplate}" SortMemberPath="DescriptionLength" Width="96">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="Desc. len" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenDescriptionLengthFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding OpenFor}" SortMemberPath="OpenForMinutes" Width="110">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Open for" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenOpenForFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource TimeToFirstResponseCellTemplate}" SortMemberPath="TimeToFirstResponseMinutes" Width="110">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="TTFR" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenTimeToFirstResponseFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding ActivityAgeOrMerged}" SortMemberPath="ActivityAgeOrMergedMinutes" Width="110">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Updated" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenActivityFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding CommentsCount}" SortMemberPath="CommentsCount" Width="96">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Comments" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenCommentsFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource RequestChangesCellTemplate}" SortMemberPath="RequestChanges" Width="100">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="RC" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenRequestChangesFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource ApprovalsCellTemplate}" SortMemberPath="Approvals" Width="100">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="AP" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenApprovalsFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource CurrentUserActivityCellTemplate}" SortMemberPath="CurrentUserActivity" Width="140">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="Me" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.OpenCurrentUserActivityFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Reviewed" Width="86">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsReviewed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="Recently merged pull requests">
                <Border Background="{DynamicResource PanelBrush}" BorderBrush="#12FFFFFF" BorderThickness="1" CornerRadius="12" Padding="0">
                    <DataGrid AutomationProperties.Name="Recently merged pull requests"
                              ItemsSource="{Binding MergedPullRequestsView}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Number}" SortMemberPath="Number" Width="64">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="#" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.MergedNumberFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn SortMemberPath="RepositoryName" Width="220">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="Repository" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.MergedRepositoryFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource LinkButtonStyle}" Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding RepositoryUrl}">
                                            <TextBlock Text="{Binding RepositoryName}" TextWrapping="Wrap" Foreground="{DynamicResource LinkBrush}" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn SortMemberPath="PullRequestId" Width="380">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="PR" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.MergedPullRequestFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource LinkButtonStyle}" Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding PullRequestUrl}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding PullRequestId, StringFormat=#\{0\}}" FontWeight="SemiBold" Foreground="{DynamicResource LinkBrush}" />
                                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" Foreground="{DynamicResource LinkBrush}" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding Author}" SortMemberPath="Author" Width="170">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Author" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.MergedAuthorFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource DescriptionLengthCellTemplate}" SortMemberPath="DescriptionLength" Width="96">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="Desc. len" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.MergedDescriptionLengthFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource TimeToFirstResponseCellTemplate}" SortMemberPath="TimeToFirstResponseMinutes" Width="110">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="TTFR" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.MergedTimeToFirstResponseFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding ActivityAgeOrMerged}" SortMemberPath="ActivityAgeOrMergedMinutes" Width="110">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Merged" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.MergedActivityFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding CommentsCount}" SortMemberPath="CommentsCount" Width="96">
                                <DataGridTextColumn.Header><StackPanel><TextBlock Text="Comments" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.MergedCommentsFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource RequestChangesCellTemplate}" SortMemberPath="RequestChanges" Width="100">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="RC" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.MergedRequestChangesFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource ApprovalsCellTemplate}" SortMemberPath="Approvals" Width="100">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="AP" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.MergedApprovalsFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn CellTemplate="{StaticResource CurrentUserActivityCellTemplate}" SortMemberPath="CurrentUserActivity" Width="140">
                                <DataGridTemplateColumn.Header><StackPanel><TextBlock Text="Me" /><TextBox Style="{StaticResource HeaderFilterTextBoxStyle}" Text="{Binding DataContext.MergedCurrentUserActivityFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></DataGridTemplateColumn.Header>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Reviewed" Width="86">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsReviewed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="Telemetry">
                <views:TelemetryView />
            </TabItem>
        </TabControl>
    </Grid>

        <views:LoadingOverlay Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
    </Grid>
</Window>
