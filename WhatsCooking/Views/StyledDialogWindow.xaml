<Window x:Class="WhatsCooking.Views.StyledDialogWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DialogTitle, RelativeSource={RelativeSource Self}}"
        Width="440"
        SizeToContent="Height"
        MinWidth="360"
        MaxWidth="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        FontFamily="Segoe UI"
        FontSize="13"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WhatsCooking;component/Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="14,9"
                    Background="{DynamicResource HeaderPanelBrush}"
                    BorderBrush="{DynamicResource SubtleBorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding DialogTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontWeight="SemiBold" />
                    <Button Grid.Column="1"
                            Width="24"
                            Height="24"
                            Padding="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            AutomationProperties.Name="Close dialog"
                            Click="OnCancelClick"
                            Content="x"
                            Style="{DynamicResource ActionButtonStyle}" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,18,20,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="34"
                        Height="34"
                        Background="{DynamicResource AccentBrush}"
                        CornerRadius="17">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="{Binding IconText, RelativeSource={RelativeSource AncestorType=Window}}" />
                </Border>

                <TextBlock Grid.Column="2"
                           Text="{Binding Message, RelativeSource={RelativeSource AncestorType=Window}}"
                           TextWrapping="Wrap"
                           LineHeight="20" />
            </Grid>

            <Border Grid.Row="2"
                    Padding="16,12"
                    Background="{DynamicResource PanelAltBrush}"
                    CornerRadius="0,0,8,8">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="ConfirmButton"
                            Width="86"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="{Binding ConfirmText, RelativeSource={RelativeSource AncestorType=Window}}"
                            Click="OnConfirmClick"
                            Content="{Binding ConfirmText, RelativeSource={RelativeSource AncestorType=Window}}"
                            IsDefault="{Binding IsConfirmationDialog, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{DynamicResource PrimaryButtonStyle}" />
                    <Button x:Name="CancelButton"
                            Width="86"
                            AutomationProperties.Name="{Binding CancelText, RelativeSource={RelativeSource AncestorType=Window}}"
                            Click="OnCancelClick"
                            Content="{Binding CancelText, RelativeSource={RelativeSource AncestorType=Window}}"
                            IsCancel="True"
                            Style="{DynamicResource ActionButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
