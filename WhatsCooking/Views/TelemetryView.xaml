<UserControl x:Class="WhatsCooking.Views.TelemetryView"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource SubtleBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Text="Enabled" Style="{DynamicResource MutedTextStyle}" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding TelemetryDashboard.IsTelemetryEnabled}" FontWeight="SemiBold" Margin="0,0,22,0" />
                    <TextBlock Text="Requests" Style="{DynamicResource MutedTextStyle}" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding TelemetryDashboard.TelemetryRequestsCount}" FontWeight="SemiBold" Margin="0,0,22,0" />
                    <TextBlock Text="Endpoints" Style="{DynamicResource MutedTextStyle}" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding TelemetryDashboard.TelemetryEndpointsCount}" FontWeight="SemiBold" Margin="0,0,22,0" />
                    <TextBlock Text="Activity cached"
                               Style="{DynamicResource MutedTextStyle}"
                               Margin="0,0,6,0"
                               ToolTip="PR metadata is always requested to validate the cache. This count shows activity summaries reused without calling the pull request activity API." />
                    <TextBlock Text="{Binding TelemetryDashboard.CacheHits}"
                               FontWeight="SemiBold"
                               Margin="0,0,22,0"
                               ToolTip="PR activity summaries reused from cache." />
                    <TextBlock Text="Activity API loads"
                               Style="{DynamicResource MutedTextStyle}"
                               Margin="0,0,6,0"
                               ToolTip="PR activity API loads required after the cache was missing or stale." />
                    <TextBlock Text="{Binding TelemetryDashboard.CacheMisses}"
                               FontWeight="SemiBold"
                               Margin="0,0,22,0"
                               ToolTip="PR activity API loads required after the cache was missing or stale." />
                    <TextBlock Text="Activity cache rate"
                               Style="{DynamicResource MutedTextStyle}"
                               Margin="0,0,6,0"
                               ToolTip="Share of PR activity summaries reused from cache. PR metadata requests are not included." />
                    <TextBlock Text="{Binding TelemetryDashboard.CacheHitRate}"
                               FontWeight="SemiBold"
                               ToolTip="Share of PR activity summaries reused from cache. PR metadata requests are not included." />
                </WrapPanel>
                <TextBlock Grid.Column="1" Text="Filter" Style="{DynamicResource MutedTextStyle}" Margin="18,0,6,0" />
                <TextBox Grid.Column="2"
                         AutomationProperties.Name="Telemetry filter"
                         Text="{Binding TelemetryDashboard.TelemetryFilter, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <DataGrid Grid.Row="1"
                      AutomationProperties.Name="Bitbucket API telemetry"
                      ItemsSource="{Binding TelemetryDashboard.TelemetryView}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Number}" SortMemberPath="Number" Width="70" />
                    <DataGridTextColumn Header="Bitbucket API" Binding="{Binding ApiName}" SortMemberPath="ApiName" Width="*" />
                    <DataGridTextColumn Header="Requests" Binding="{Binding RequestCount}" SortMemberPath="RequestCount" Width="130" />
                    <DataGridTextColumn Header="Share" Binding="{Binding ShareText}" SortMemberPath="Share" Width="110" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
