<UserControl x:Class="WhatsCooking.Views.DashboardToolbar"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:WhatsCooking.Views">
    <UserControl.Resources>
        <views:ThemeSelectionVisibilityConverter x:Key="ThemeSelectionVisibilityConverter" />
    </UserControl.Resources>

    <Border Margin="10,8,10,0"
            Padding="10,8"
            Background="{DynamicResource HeaderPanelBrush}"
            BorderBrush="{DynamicResource SubtleBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="What's Cooking" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1"
                           Margin="16,0,0,0"
                           AutomationProperties.Name="Loaded pull request data timestamp"
                           Text="{Binding LoadedAt}"
                           Style="{DynamicResource MutedTextStyle}" />
                <TextBlock Grid.Column="3" Text="{Binding Status}" Style="{DynamicResource MutedTextStyle}" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="132" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Search mode" Style="{DynamicResource MutedTextStyle}" Margin="0,0,6,0" />
                <ComboBox Grid.Column="1"
                          AutomationProperties.Name="Repository search mode"
                          ItemsSource="{Binding SearchModes}"
                          SelectedItem="{Binding SelectedSearchMode}" />

                <TextBlock Grid.Column="3" Text="Phrase" Style="{DynamicResource MutedTextStyle}" Margin="0,0,6,0" />
                <TextBox Grid.Column="4"
                         AutomationProperties.Name="Repository search phrase"
                         Text="{Binding SearchPhrase, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="6" Text="Days" Style="{DynamicResource MutedTextStyle}" Margin="0,0,6,0" />
                <TextBox Grid.Column="7"
                         AutomationProperties.Name="Recently merged pull request period in days"
                         Text="{Binding MergedPullRequestsDaysInput,
                                        UpdateSourceTrigger=PropertyChanged,
                                        ValidatesOnNotifyDataErrors=True}" />

                <TextBox Grid.Column="9"
                         AutomationProperties.Name="Global pull request search"
                         Text="{Binding GlobalSearch, UpdateSourceTrigger=PropertyChanged, Delay=250}"
                         ToolTip="Global search across all columns" />

                <Button Grid.Column="11" Content="Load" Command="{Binding LoadCommand}" Style="{DynamicResource LoadButtonStyle}" />
                <Button Grid.Column="13"
                        Content="Fit"
                        Click="OnFitColumnsClick"
                        Style="{DynamicResource ActionButtonStyle}"
                        ToolTip="Fit the current grid columns to the window width" />
                <Button Grid.Column="15" Content="Reset Filters" Command="{Binding ResetFiltersCommand}" Style="{DynamicResource ActionButtonStyle}" />

                <Grid Grid.Column="17" Grid.ColumnSpan="3">
                    <Button x:Name="HeaderMenuButton"
                            AutomationProperties.Name="Dashboard menu"
                            Style="{DynamicResource HeaderMenuButtonStyle}"
                            ClickMode="Press"
                            Click="OnToggleHeaderMenuClick">
                        <Path Width="16"
                              Height="12"
                              Stretch="Fill"
                              Stroke="{DynamicResource TextBrush}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 1,1 L 15,1 M 1,6 L 15,6 M 1,11 L 15,11" />
                    </Button>

                    <Popup x:Name="HeaderMenuPopup"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=HeaderMenuButton}"
                           VerticalOffset="8"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           StaysOpen="False"
                           Closed="OnHeaderMenuClosed">
                        <Border MinWidth="188"
                                Padding="8"
                                Background="{DynamicResource PanelAltBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <Grid Margin="0,0,0,2" MinHeight="42">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Margin="12,0,8,0"
                                               FontWeight="SemiBold"
                                               Text="Zoom" />
                                    <Button Grid.Column="1"
                                            Style="{DynamicResource HeaderPopupIconButtonStyle}"
                                            Command="{Binding DecreaseUiScaleCommand}"
                                            Content="-" />
                                    <TextBlock Grid.Column="2"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Text="{Binding UiScale, StringFormat={}{0:P0}}" />
                                    <Button Grid.Column="3"
                                            Style="{DynamicResource HeaderPopupIconButtonStyle}"
                                            Command="{Binding IncreaseUiScaleCommand}"
                                            Content="+" />
                                </Grid>

                                <Button Style="{DynamicResource HeaderPopupButtonStyle}"
                                        Click="OnToggleThemeMenuClick">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Theme" />
                                        <TextBlock Grid.Column="1" Text="&gt;" Foreground="{DynamicResource MutedBrush}" />
                                    </Grid>
                                </Button>

                                <Border x:Name="ThemeMenuItemsPanel"
                                        Margin="0,2,0,0"
                                        Padding="6,0,0,0"
                                        BorderBrush="{DynamicResource SubtleBorderBrush}"
                                        BorderThickness="1,0,0,0"
                                        Visibility="Collapsed">
                                    <ItemsControl ItemsSource="{Binding ThemeOptions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{DynamicResource HeaderPopupSubButtonStyle}"
                                                        Click="OnThemeModeMenuItemClick">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="18" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <Ellipse Width="6"
                                                                 Height="6"
                                                                 Fill="{DynamicResource DangerBrush}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center">
                                                            <Ellipse.Visibility>
                                                                <MultiBinding Converter="{StaticResource ThemeSelectionVisibilityConverter}">
                                                                    <Binding Path="Mode" />
                                                                    <Binding Path="DataContext.ThemeMode" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                                </MultiBinding>
                                                            </Ellipse.Visibility>
                                                        </Ellipse>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Label}"
                                                                   Foreground="{DynamicResource MutedBrush}" />
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
