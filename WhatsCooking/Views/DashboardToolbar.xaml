<UserControl x:Class="WhatsCooking.Views.DashboardToolbar"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Margin="10,8,10,0"
            Padding="10,8"
            Background="{DynamicResource HeaderPanelBrush}"
            BorderBrush="{DynamicResource SubtleBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="What's Cooking" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding Status}" Style="{StaticResource MutedTextStyle}" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Search mode" Style="{StaticResource MutedTextStyle}" Margin="0,0,6,0" />
                <ComboBox Grid.Column="1"
                          AutomationProperties.Name="Repository search mode"
                          ItemsSource="{Binding SearchModes}"
                          SelectedItem="{Binding SelectedSearchMode}" />

                <TextBlock Grid.Column="3" Text="Phrase" Style="{StaticResource MutedTextStyle}" Margin="0,0,6,0" />
                <TextBox Grid.Column="4"
                         AutomationProperties.Name="Repository search phrase"
                         Text="{Binding SearchPhrase, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="6" Text="Days" Style="{StaticResource MutedTextStyle}" Margin="0,0,6,0" />
                <TextBox Grid.Column="7"
                         AutomationProperties.Name="Recently merged pull request period in days"
                         Text="{Binding MergedPullRequestsDaysInput,
                                        UpdateSourceTrigger=PropertyChanged,
                                        ValidatesOnNotifyDataErrors=True}" />

                <TextBox Grid.Column="9"
                         AutomationProperties.Name="Global pull request search"
                         Text="{Binding GlobalSearch, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Global search across all columns" />

                <Button Grid.Column="11" Content="Load" Command="{Binding LoadCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                <Button Grid.Column="13" Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource ActionButtonStyle}" />
                <Button Grid.Column="15" Content="Reset Filters" Command="{Binding ResetFiltersCommand}" Style="{StaticResource ActionButtonStyle}" />
                <TextBlock Grid.Column="17" Text="Theme" Style="{StaticResource MutedTextStyle}" />
                <CheckBox Grid.Column="19"
                          AutomationProperties.Name="Use light theme"
                          IsChecked="{Binding IsLightTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource ThemeToggleSwitchStyle}"
                          ToolTip="Switch theme" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
